{
  "expo": {
    "name": "Cher Ami",
    "slug": "cherami",
    "version": "1.0.7",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "cherami",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.hollowinc.cherami",
      "icon": "./assets/images/icon.png",
      "supportsTablet": true,
      "usesAppleSignIn": true,
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "NSCameraUsageDescription": "This app may use your camera if you choose to take a new photo rather than selecting one from your library when prompted.",
        "NSPhotoLibraryUsageDescription": "This app allows you to choose photos from your library to share with your family.",
        "UIBackgroundModes": ["remote-notification"],
        "NSLocationWhenInUseUsageDescription": "This app may use your location to enhance push notifications and location-based features."
      },
      "entitlements": {
        "aps-environment": "production",
        "com.apple.security.application-groups": [
          "group.com.hollowinc.cherami.onesignal"
        ]
      }
    },
    "android": {
      "package": "com.hollowinc.cherami",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/foreground.png",
        "backgroundColor": "#C15F3C"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-apple-authentication",
      "expo-router",
      [
        "onesignal-expo-plugin",
        {
          "mode": "production"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#C15F3C"
        }
      ],
      [
        "expo-secure-store",
        {
          "configureAndroidBackup": true,
          "faceIDPermission": "Allow $(PRODUCT_NAME) to access your Face ID biometric data."
        }
      ],
      [
        "expo-font",
        {
          "fonts": ["./assets/fonts/Damion-Regular.ttf"],
          "android": {
            "fonts": [
              {
                "fontFamily": "Poppins",
                "fontDefinitions": [
                  {
                    "path": "./assets/fonts/Poppins-Regular.ttf",
                    "weight": 400
                  },
                  {
                    "path": "./assets/fonts/Poppins-Medium.ttf",
                    "weight": 500
                  },
                  {
                    "path": "./assets/fonts/Poppins-SemiBold.ttf",
                    "weight": 600
                  }
                ]
              }
            ]
          },
          "ios": {
            "fonts": [
              "./assets/fonts/Poppins-Regular.ttf",
              "./assets/fonts/Poppins-Medium.ttf",
              "./assets/fonts/Poppins-SemiBold.ttf"
            ]
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5bdc80eb-f8d9-4f7a-a8e0-0c523d26c8dd"
      }
    },
    "owner": "hollow-inc"
  }
}

